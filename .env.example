# Copy this file to the repository root as `.env` (recommended).
# Services load root `.env` first, then `services/<name>/.env` overrides if present.

# Browser origin for CORS (both APIs)
WEB_ORIGIN=http://localhost:5173

# --- Pipedream Connect ---
PIPEDREAM_CLIENT_ID=
PIPEDREAM_CLIENT_SECRET=
PIPEDREAM_PROJECT_ID=
# development | production (use development for localhost; see Pipedream Connect environments docs)
PIPEDREAM_PROJECT_ENVIRONMENT=development
PIPEDREAM_API_PORT=3001

# --- Gemini (server-only; never expose to Vite) ---
# Google AI Studio: https://aistudio.google.com/apikey
GEMINI_API_KEY=
# Model id must match what your key can call (free tier changes over time). Override if smoke fails.
# If one model hits daily RPM/RPD, try another id your AI Studio quota page still has headroom for, e.g.:
#   gemini-2.0-flash  |  gemini-1.5-flash  |  gemini-2.5-flash
GEMINI_MODEL=gemini-2.5-flash
CHAT_API_PORT=3002

# --- React (Vite) — optional overrides ---
# VITE_PIPEDREAM_API_URL=http://localhost:3001
# VITE_CHAT_API_URL=http://localhost:3002

