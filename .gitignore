# ── Dependencies ──────────────────────────────────────────────────────────────
node_modules/

# ── Build outputs ─────────────────────────────────────────────────────────────
dist/
# Vite cache / pre-bundled deps
.vite/
# TypeScript incremental build info
*.tsbuildinfo

# ── Environment / secrets ─────────────────────────────────────────────────────
