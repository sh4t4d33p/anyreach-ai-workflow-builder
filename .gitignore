.env
.env.local
.env.*.local

# ── Logs ──────────────────────────────────────────────────────────────────────
*.log
npm-debug.log*

# ── OS artefacts ──────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── Editor / IDE ──────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
